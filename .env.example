# ── Supabase (Auth + PostgreSQL) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=xxx

# ── Firebase Hosting uniquement — ne pas supprimer ────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ── RevenueCat — clé publique web ─────────────────────────────────────────────
VITE_REVENUECAT_API_KEY=your_revenuecat_web_api_key

# ── Supabase Edge Function Secrets (à configurer via supabase secrets set) ────
# FIREBASE_API_KEY = VITE_FIREBASE_API_KEY (même valeur — côté serveur Edge Function)
# SUPABASE_JWT_SECRET = disponible automatiquement dans les Edge Functions

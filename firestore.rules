rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isValidString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();

      // Le rôle ne peut être écrit que par le propriétaire ou l'admin,
      // et uniquement vers des valeurs autorisées.
      allow update: if isOwner(userId)
        && (!("role" in request.resource.data)
          || request.resource.data.role == resource.data.role);

      // Données journalières de suivi (une doc par mois YYYY_M)
      match /days/{monthDoc} {
        allow read, write: if isOwner(userId);
      }

      // Entrées de journal
      match /journal/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // Préférences : trackers, humeurs, thème, langue…
      match /settings/{settingDoc} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Feedbacks ──────────────────────────────────────────────────────────────
    match /feedbacks/{feedbackId} {
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.text, 2000)
        && request.resource.data.type in ["bug", "idea"]
        && request.resource.data.keys().hasOnly(["userId", "type", "text", "createdAt"]);

      allow read: if isAuth()
        && request.auth.uid == resource.data.userId;

      allow read, update: if isAdmin();
    }

    // ── Roadmap ────────────────────────────────────────────────────────────────
    match /roadmap/{itemId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Config publique (maintenance, version min) ─────────────────────────────
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Bloquer tout le reste par défaut ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
